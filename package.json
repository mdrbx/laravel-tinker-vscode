{
  "name": "laravel-tinker-vscode",
  "displayName": "Laravel Tinker (Unofficial)",
  "description": "Run Laravel Tinker in VS Code with color-coded output, execution history, and custom PHP runtime support. Based on laravel-runner by ali-raza-saleem (https://github.com/ali-raza-saleem/laravel-runner).",
  "version": "1.0.2",
  "publisher": "mdrbx",
  "icon": "resources/icons/logo.png",
  "galleryBanner": {
    "color": "#0e1425",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mdrbx/laravel-tinker-vscode.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/mdrbx/laravel-tinker-vscode",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "tinker",
    "tinker runner",
    "laravel playground",
    "laravel tinker",
    "laravel code runner",
    "laravel repl",
    "run php code",
    "php runner",
    "laravel runner",
    "artisan tinker",
    "sail",
    "docker"
  ],
  "activationEvents": [
    "onLanguage:php",
    "onCommand:laravelTinker.runPhpFile",
    "onCommand:laravelTinker.clearOutput",
    "onCommand:laravelTinker.focusSearchBar",
    "onCommand:laravelTinker.installPlayground"
  ],
  "main": "./dist/extension.min.js",
  "files": [
    "dist/",
    "assets",
    "resources/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "laravelTinker.runPhpFile",
        "title": "Laravel Tinker: Run PHP File",
        "icon": "$(play)"
      },
      {
        "command": "laravelTinker.stopPhpFile",
        "title": "Laravel Tinker: Stop PHP File",
        "icon": "$(debug-stop)"
      },
      {
        "command": "laravelTinker.clearOutput",
        "title": "Laravel Tinker: Clear Output"
      },
      {
        "command": "laravelTinker.focusSearchBar",
        "title": "Laravel Tinker: Focus Search Bar"
      },
      {
        "command": "laravelTinker.installPlayground",
        "title": "Laravel Tinker: Install Playground"
      },
      {
        "command": "laravelTinker.showHistory",
        "title": "Laravel Tinker: Show History"
      },
      {
        "command": "laravelTinker.clearHistory",
        "title": "Laravel Tinker: Clear History"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+r",
        "command": "laravelTinker.runPhpFile",
        "when": "editorLangId == php"
      },
      {
        "key": "ctrl+alt+c",
        "command": "laravelTinker.clearOutput",
        "when": "editorLangId == php || webviewFocus"
      },
      {
        "key": "ctrl+alt+f",
        "command": "laravelTinker.focusSearchBar",
        "when": "editorLangId == php || webviewFocus"
      },
      {
        "key": "ctrl+alt+h",
        "command": "laravelTinker.showHistory",
        "when": "editorLangId == php || webviewFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "laravelTinker.runPhpFile",
          "when": "editorLangId == php && !laravelTinker.isRunning",
          "group": "navigation"
        },
        {
          "command": "laravelTinker.stopPhpFile",
          "when": "editorLangId == php && laravelTinker.isRunning",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "laravelTinker.installPlayground",
          "when": "workspaceFolderCount > 0",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Laravel Tinker (Unofficial)",
      "properties": {
        "laravelTinker.playgroundFolder": {
          "type": "string",
          "default": ".tinker",
          "description": "The folder inside the Laravel project where PHP files can be executed."
        },
        "laravelTinker.appendOutput": {
          "type": "boolean",
          "default": true,
          "description": "Preserve output from previous runs and append new output."
        },
        "laravelTinker.phpCommand": {
          "type": "string",
          "default": "php",
          "description": "The command used to run PHP. Examples: 'php', 'sail php', 'docker-compose exec app php'."
        },
        "laravelTinker.historyEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable execution history stored in a local JSON database."
        },
        "laravelTinker.historyMaxEntries": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of history entries to keep."
        },
        "laravelTinker.historyMaxSizeMb": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 2000,
          "description": "Maximum total size of history database in megabytes."
        }
      }
    }
  },
  "customConfig": {
    "tinkerScriptPath": "./resources/tinker.php"
  },
  "scripts": {
    "build": "webpack --mode production",
    "lint": "eslint src resources/js/ --ext .ts,.js --fix",
    "format": "prettier --write src resources/js/ resources/css/ ",
    "fix-style": "npm run format && npm run lint",
    "package": "npm run build && vsce package --out ./packages/",
    "package-patch": "npm version patch && npm run package",
    "package-minor": "npm version minor && npm run package",
    "package-major": "npm version major && npm run package"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vscode/test-electron": "^2.4.1",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "esbuild": "^0.25.1",
    "esbuild-loader": "^4.3.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "file-loader": "^6.2.0",
    "glob": "^11.0.1",
    "mark.js": "^8.11.1",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^3.5.3",
    "style-loader": "^4.0.0",
    "thread-loader": "^4.0.4",
    "ts-loader": "^9.5.2",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "alpinejs": "^3.14.8",
    "highlight.js": "^11.11.1",
    "mitt": "^3.0.1"
  }
}
